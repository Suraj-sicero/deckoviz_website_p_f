PORT=5000

# ── Database ──────────────────────────────────────────
# PostgreSQL (preferred). If unset, falls back to SQLite.
# DATABASE_URL=postgresql://user:pass@host:5432/deckoviz
# Or use individual vars:
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=your_password
# PG_DATABASE=deckoviz

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_string

# ── AI / LLM APIs (all optional) ──────────────────────
# GOOGLE_API_KEY=your_gemini_key
# GEMINI_API_KEY=your_gemini_key
# GROQ_API_KEY=your_groq_key
# REPLICATE_API_TOKEN=your_replicate_token
# RUNWARE_API_KEY=your_runware_key
# ELEVENLABS_API_KEY=your_elevenlabs_key
# MURF_API_KEY=your_murf_key
# MUSIC_API_KEY=your_music_api_key
# MARBLE_KEY=your_marble_key
# FAL_KEY=your_fal_key

# ── Media Storage ─────────────────────────────────────
# Cloudinary (preferred). Falls back to local disk.
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ── Redis ──────────────────────────────────────────────
# REDIS_URL=redis://default:password@host:6379

# ── Stripe ─────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...

# ── Mobile Webhook ────────────────────────────────────
# MOBILE_WEBHOOK_URL=https://your-push-service.com/webhook
# MOBILE_WEBHOOK_SECRET=your_webhook_secret

# ── Deployment ─────────────────────────────────────────
# RENDER_EXTERNAL_URL=https://your-app.onrender.com
# BACKEND_URL=https://your-custom-domain.com
